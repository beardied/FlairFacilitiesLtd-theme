{
    "$schema": "https://schemas.wp.org/wp/6.5/theme.json",
    "version": 2,
    "settings": {
        "appearanceTools": true,
        "color": {
            "defaultPalette": false,
            "palette": [
                { "color": "#0a1628", "name": "Dark Navy", "slug": "dark-navy" },
                { "color": "#1e3a8a", "name": "Primary Blue", "slug": "primary-blue" },
                { "color": "#2563eb", "name": "Bright Blue", "slug": "bright-blue" },
                { "color": "#dc2626", "name": "Accent Red", "slug": "accent-red" },
                { "color": "#ea580c", "name": "Orange", "slug": "orange" },
                { "color": "#f8fafc", "name": "Off White", "slug": "off-white" },
                { "color": "#e2e8f0", "name": "Light Gray", "slug": "light-gray" },
                { "color": "#64748b", "name": "Muted", "slug": "muted" },
                { "color": "#ffffff", "name": "White", "slug": "white" }
            ],
            "gradients": [
                { "gradient": "linear-gradient(135deg, #1e3a8a 0%, #0a1628 100%)", "name": "Blue Gradient", "slug": "blue-gradient" },
                { "gradient": "linear-gradient(135deg, #dc2626 0%, #ea580c 100%)", "name": "Red Gradient", "slug": "red-gradient" }
            ]
        },
        "typography": {
            "fontFamilies": [
                { "fontFamily": "'Inter', system-ui, -apple-system, sans-serif", "name": "Inter", "slug": "inter" }
            ],
            "fontSizes": [
                { "name": "Small", "size": "0.875rem", "slug": "small" },
                { "name": "Base", "size": "1rem", "slug": "base" },
                { "name": "Large", "size": "1.125rem", "slug": "large" },
                { "name": "XL", "size": "1.5rem", "slug": "xl" },
                { "name": "2XL", "size": "2rem", "slug": "2xl" },
                { "name": "3XL", "size": "2.5rem", "slug": "3xl" },
                { "name": "Hero", "size": "clamp(2.2rem, 5vw, 3.8rem)", "slug": "hero" }
            ]
        },
        "spacing": {
            "units": ["px", "em", "rem", "vh", "vw", "%"],
            "padding": true,
            "margin": true,
            "blockGap": true
        },
        "layout": {
            "contentSize": "768px",
            "wideSize": "1200px"
        }
    },
    "styles": {
        "color": {
            "background": "#ffffff",
            "text": "#0a1628"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--inter)",
            "fontSize": "1rem",
            "lineHeight": "1.6"
        },
        "elements": {
            "h1": {
                "typography": { "fontSize": "var(--wp--preset--font-size--hero)", "fontWeight": "800", "lineHeight": "1.15" }
            },
            "h2": {
                "typography": { "fontSize": "var(--wp--preset--font-size--3xl)", "fontWeight": "700", "lineHeight": "1.2" }
            },
            "h3": {
                "typography": { "fontSize": "var(--wp--preset--font-size--2xl)", "fontWeight": "700", "lineHeight": "1.3" }
            },
            "link": {
                "color": { "text": "var(--wp--preset--color--primary-blue)" }
            }
        }
    },
    "templateParts": [
        { "name": "header", "area": "header" },
        { "name": "footer", "area": "footer" }
    ],
    "customTemplates": [
        { "name": "front-page", "title": "Front Page", "postTypes": ["page"] }
    ]
}
